{
  "name": "nft-miner-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node tools/run-node-tests.mjs tests",
    "server:dev": "node --watch server/src/index.js",
    "server:start": "node server/src/index.js",
    "server:build": "node server/scripts/check.mjs",
    "server:migrate": "node server/scripts/migrate.mjs",
    "server:cleanup:sessions": "node server/scripts/cleanup-sessions.mjs",
    "server:cleanup:auth-challenges": "node server/scripts/cleanup-auth-challenges.mjs",
    "server:cleanup:idempotency": "node server/scripts/cleanup-idempotency-keys.mjs",
    "server:cleanup:payment-orders": "node server/scripts/cleanup-payment-orders.mjs",
    "server:cleanup:rate-limits": "node server/scripts/cleanup-rate-limit-keys.mjs",
    "server:test": "node tools/run-node-tests.mjs server/tests",
    "server:payments:check": "node server/scripts/check-payments-config.mjs",
    "smoke:api": "node tools/smoke-api.mjs",
    "e2e": "playwright test",
    "load:smoke": "node load-tests/run.mjs --profile smoke",
    "load:api": "node load-tests/run.mjs --profile api",
    "worker:payments": "node server/src/workers/paymentsWorker.js",
    "deploy:demo-vm": "powershell -ExecutionPolicy Bypass -File tools/deploy-demo-vm.ps1",
    "watch:deploy:demo-vm": "powershell -ExecutionPolicy Bypass -File tools/watch-deploy-demo-vm.ps1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/test": "^1.59.1",
    "@upstash/context7-mcp": "^2.1.2",
    "autocannon": "^8.0.0",
    "netlify": "^24.0.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.4",
    "@tonconnect/ui": "^2.4.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "mobile-drag-drop": "^3.0.0-rc.0",
    "pg": "^8.20.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.6"
  }
}
